<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Kropka nieprzeczytanej wiadomości -->
        <View
            android:id="@+id/viewUnreadDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/shape_dot_unread"
            android:layout_marginEnd="12dp"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtMsgSender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nadawca@email.com"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary"/>

            <TextView
                android:id="@+id/txtMsgSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temat wiadomości"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/txtMsgBodySnippet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To jest fragment treści wiadomości..."
                android:textSize="14sp"
                android:alpha="0.7"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/txtMsgDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:45"
            android:textSize="12sp"
            android:alpha="0.6"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
