<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEBUG: Theme Switcher Test"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textColor="@color/text_primary"/>

    <!-- Wariant 1: Custom Drawables na standardowym Switchu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wariant 1 (Standard Switch + Custom Drawables)"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/debugSwitch1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:thumbTint="@null"
        app:trackTint="@null"
        android:thumb="@drawable/theme_switch_thumb"
        android:track="@drawable/theme_switch_track"
        app:switchMinWidth="72dp"
        android:layout_marginBottom="40dp"/>

    <!-- Wariant 2: Symulacja wyglądu przez FrameLayout (jeśli Switch zawiedzie) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wariant 2 (Manual Mockup)"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <FrameLayout
        android:id="@+id/debugSwitchMock"
        android:layout_width="72dp"
        android:layout_height="40dp"
        android:background="@drawable/theme_switch_track">

        <ImageView
            android:id="@+id/mockThumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/theme_switch_thumb"
            android:layout_gravity="start"/>

    </FrameLayout>

    <Button
        android:id="@+id/btnBackFromDebug"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Powrót"
        android:layout_marginTop="64dp"/>

</LinearLayout>
