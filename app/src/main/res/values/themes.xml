<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.SchoolSpace" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.SchoolSpace" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Kolory podstawowe -->
        <item name="colorPrimary">@color/primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:textColor">@color/text_primary</item>

        <!-- Pasek systemowy (StatusBar) -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Pasek nawigacji dolnej systemowej -->
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.SchoolSpace.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
</resources>
